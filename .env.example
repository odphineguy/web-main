# Groq API Key (for the text chatbot — Llama 3.3 70B)
# Copy this file to .env.local and replace with your actual API key.
# Free tier, no credit card required: https://console.groq.com/keys
# IMPORTANT: This key is server-side only (no NEXT_PUBLIC_ prefix).
GROQ_API_KEY=

# Google Gemini API Key (still used by the live-voice session in ChatbotApp.tsx)
# Get your API key from: https://aistudio.google.com/app/apikey
NEXT_PUBLIC_API_KEY=
